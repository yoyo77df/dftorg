rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isImageUnder(maxBytes) {
      return request.resource != null
        && request.resource.size < maxBytes
        && request.resource.contentType.matches('image/.*');
    }

    // Profile avatars: owner can upload/update, signed-in users can view.
    match /avatars/{userId}/{file=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.auth.uid == userId
        && isImageUnder(2 * 1024 * 1024);
    }

    // Deposit proof screenshots: owner uploads, owner/admin can view.
    match /deposits/{userId}/{file=**} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn()
        && request.auth.uid == userId
        && isImageUnder(5 * 1024 * 1024);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}