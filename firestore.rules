rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isSelf(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    // Fields a user must NEVER be able to set/change on themselves
    function touchesPrivileged(data, prev) {
      return data.diff(prev).affectedKeys()
        .hasAny(['role','balance','earnings','wins','xp','rank','tier',
                 'is_banned','total_kills','matches_played']);
    }
    function onlyBalanceDecrease(data, prev) {
      return data.diff(prev).affectedKeys().hasOnly(['balance'])
        && data.balance is number
        && (!('balance' in prev) || !(prev.balance is number) || data.balance <= prev.balance);
    }
    function oldJoinedSlots() {
      return resource.data.joined_slots is number ? resource.data.joined_slots : 0;
    }
    function joinedSlotIncrementOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['joined_slots', 'updated_at'])
        && request.resource.data.joined_slots is number
        && request.resource.data.joined_slots == oldJoinedSlots() + 1;
    }
    function hasNoSiteOwner() {
      return isSignedIn()
        && !exists(/databases/$(database)/documents/app_settings/site_owner);
    }

    // ---------- USERS ----------
    match /users/{uid} {
      allow read: if isSignedIn();
      // Self-create only with role=user (or unset) and no privileged stat injection
      allow create: if isSelf(uid)
        && (!('role' in request.resource.data) || request.resource.data.role == 'user')
        && (!('balance' in request.resource.data) || request.resource.data.balance == 0)
        && (!('earnings' in request.resource.data) || request.resource.data.earnings == 0)
        && (!('is_banned' in request.resource.data) || request.resource.data.is_banned == false);
      // Self-update: profile fields only — never privileged fields
      allow update: if (isSelf(uid) && !touchesPrivileged(request.resource.data, resource.data))
                    || (isSelf(uid) && onlyBalanceDecrease(request.resource.data, resource.data))
                    || (isSelf(uid) && hasNoSiteOwner()
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role'])
                        && request.resource.data.role == 'admin')
                    || isAdmin();
      allow delete: if isAdmin();
    }

    // ---------- WALLET LEDGER (read-only for users) ----------
    match /wallet_transactions/{id} {
      allow read: if isSignedIn() && (isSelf(resource.data.user_id) || isAdmin());
      allow write: if isAdmin();
    }

    // ---------- DEPOSITS ----------
    match /deposits/{id} {
      allow read: if isSignedIn() && (isSelf(resource.data.user_id) || isAdmin());
      allow create: if isSignedIn()
        && isSelf(request.resource.data.user_id)
        && request.resource.data.status == 'pending'
        && request.resource.data.amount is number
        && request.resource.data.amount > 0;
      allow update, delete: if isAdmin();
    }

    // ---------- WITHDRAWALS ----------
    match /withdrawals/{id} {
      allow read: if isSignedIn() && (isSelf(resource.data.user_id) || isAdmin());
      allow create: if isSignedIn()
        && isSelf(request.resource.data.user_id)
        && request.resource.data.status == 'pending'
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.amount <=
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.balance;
      allow update, delete: if isAdmin();
    }

    // ---------- TOURNAMENTS ----------
    match /tournaments/{id} {
      // Public tournament cards/details are safe to read. Room credentials live in tournament_secrets.
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (isSignedIn() && joinedSlotIncrementOnly());
    }

    // Top-level participants collection (doc id = `${tournamentId}_${uid}`)
    match /tournament_participants/{pid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && isSelf(request.resource.data.user_id)
        && request.resource.data.tournament_id is string;
      allow update, delete: if isAdmin();
    }

    // Room credentials — only joined participants or admins may read.
    match /tournament_secrets/{tid} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        exists(/databases/$(database)/documents/tournament_participants/$(tid + '_' + request.auth.uid))
      );
      allow write: if isAdmin();
    }

    // ---------- NOTIFICATIONS ----------
    match /notifications/{id} {
      allow read: if isSignedIn() &&
        (resource.data.user_id == null || resource.data.user_id == 'all' || isSelf(resource.data.user_id) || isAdmin());
      // Broadcast notifications (user_id == null) may only be updated by admins.
      allow update: if isSignedIn() &&
        (isSelf(resource.data.user_id) || isAdmin());
      allow create, delete: if isAdmin();
    }

    // ---------- SUPPORT / CHAT (private threads) ----------
    match /support_threads/{tid} {
      allow read: if isSignedIn() && (isSelf(resource.data.user_id) || isAdmin());
      allow create: if isSignedIn() && (isSelf(request.resource.data.user_id) || isAdmin());
      allow update, delete: if isSignedIn() && (isSelf(resource.data.user_id) || isAdmin());
      match /messages/{mid} {
        allow read, create: if isSignedIn() &&
          (isSelf(get(/databases/$(database)/documents/support_threads/$(tid)).data.user_id) || isAdmin());
      }
    }

    match /chat_threads/{tid} {
      allow read: if isSignedIn() && (isSelf(resource.data.user_id) || isAdmin());
      allow create: if isSignedIn() && (isSelf(request.resource.data.user_id) || isAdmin());
      allow update, delete: if isSignedIn() && (isSelf(resource.data.user_id) || isAdmin());
      match /messages/{mid} {
        allow read, create: if isSignedIn() &&
          (isSelf(get(/databases/$(database)/documents/chat_threads/$(tid)).data.user_id) || isAdmin());
      }
    }

    match /support_messages/{uid}/messages/{mid} {
      allow read: if isSignedIn() && (isSelf(uid) || isAdmin());
      allow create: if isSignedIn() && (isSelf(uid) || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /chat_messages/{uid}/messages/{mid} {
      allow read: if isSignedIn() && (isSelf(uid) || isAdmin());
      allow create: if isSignedIn() && (isSelf(uid) || isAdmin());
      allow update, delete: if isAdmin();
    }

    // ---------- PUBLIC CONFIG (themes, support links) ----------
    match /app_config/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /app_settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /app_settings/site_owner {
      allow read: if true;
      allow create: if isSignedIn()
        && !exists(/databases/$(database)/documents/app_settings/site_owner)
        && request.resource.data.owner_uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}