rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------- helpers --------
    function signedIn() { return request.auth != null; }
    function isSelf(uid) { return signedIn() && request.auth.uid == uid; }
    function userDocPath() { return /databases/$(database)/documents/users/$(request.auth.uid); }
    function isAdmin() {
      return signedIn()
        && exists(userDocPath())
        && get(userDocPath()).data.role == 'admin';
    }
    function noOwnerYet() {
      return !exists(/databases/$(database)/documents/app_settings/site_owner);
    }
    function changed(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }
    function oldBalance() {
      return ('balance' in resource.data) && resource.data.balance is number ? resource.data.balance : 0;
    }
    function oldJoinedSlots() {
      return ('joined_slots' in resource.data) && resource.data.joined_slots is number ? resource.data.joined_slots : 0;
    }

    // -------- PUBLIC READS (no auth required) --------
    match /app_settings/{doc} { allow read: if true; }
    match /app_config/{doc}   { allow read: if true; }
    match /tournaments/{id}   { allow read: if true; }

    // -------- USERS --------
    match /users/{uid} {
      // Sensitive fields (email, balance, role, is_banned) live here — only owner or admin can read.
      allow read: if isAdmin() || isSelf(uid);

      // Self-create profile (only safe defaults)
      allow create: if isAdmin() || (
        isSelf(uid)
        && (!('role' in request.resource.data)    || request.resource.data.role == 'user')
        && (!('balance' in request.resource.data) || request.resource.data.balance == 0)
        && (!('is_banned' in request.resource.data)|| request.resource.data.is_banned == false)
      );

      // Updates
      allow update: if isAdmin()
        // First user can promote themselves to admin when no owner exists.
        || (isSelf(uid) && noOwnerYet() && changed(['role']) && request.resource.data.role == 'admin')
        // Self profile edits (no role/balance/ban escalation)
        || (isSelf(uid) && changed([
              'email','name','username','photoURL','country','gaming_uid',
              'bio','updatedAt','last_login_at'
            ]))
        // Self balance change ONLY allowed to decrease (e.g. tournament entry)
        || (isSelf(uid) && changed(['balance'])
            && request.resource.data.balance is number
            && request.resource.data.balance <= oldBalance());

      allow delete: if isAdmin();
    }

    // -------- PUBLIC USER PROFILE MIRROR --------
    // Non-sensitive, display-only mirror readable by any signed-in user.
    match /user_public/{uid} {
      allow read: if signedIn();
      allow create, update: if isAdmin() || (
        isSelf(uid)
        && request.resource.data.diff(resource.data.keys() == null ? {} : resource.data)
             .affectedKeys().hasOnly(['name','username','photoURL','country','gaming_uid','bio','rank','xp','wins','total_kills','matches_played','updatedAt'])
      );
      allow delete: if isAdmin();
    }

    // -------- TOURNAMENTS (writes) --------
    match /tournaments/{id} {
      allow create, delete: if isAdmin();
      // Admin can edit anything. Any signed-in user can only bump the join counter.
      allow update: if isAdmin() || (
        signedIn()
        && changed(['joined_slots','updated_at'])
        && request.resource.data.joined_slots is number
        && request.resource.data.joined_slots == oldJoinedSlots() + 1
        && existsAfter(/databases/$(database)/documents/tournament_participants/$(id + '_' + request.auth.uid))
      );
    }

    // -------- TOURNAMENT PARTICIPANTS --------
    match /tournament_participants/{pid} {
      allow read: if signedIn();
      allow create: if isAdmin() || (
        signedIn()
        && request.resource.data.user_id == request.auth.uid
        && pid == request.resource.data.tournament_id + '_' + request.auth.uid
      );
      allow update, delete: if isAdmin();
    }

    match /tournament_secrets/{tid} {
      allow read: if isAdmin() || (
        signedIn()
        && exists(/databases/$(database)/documents/tournament_participants/$(tid + '_' + request.auth.uid))
      );
      allow write: if isAdmin();
    }

    // -------- WALLET / DEPOSITS / WITHDRAWALS --------
    match /wallet_transactions/{id} {
      allow read: if signedIn() && (isAdmin() || resource.data.user_id == request.auth.uid);
      allow create: if isAdmin() || (
        signedIn()
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.amount is number
      );
      allow update, delete: if isAdmin();
    }

    match /deposits/{id} {
      allow read: if signedIn() && (isAdmin() || resource.data.user_id == request.auth.uid);
      allow create: if isAdmin() || (
        signedIn()
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
      );
      allow update, delete: if isAdmin();
    }

    match /withdrawals/{id} {
      allow read: if signedIn() && (isAdmin() || resource.data.user_id == request.auth.uid);
      allow create: if isAdmin() || (
        signedIn()
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
      );
      allow update, delete: if isAdmin();
    }

    // -------- NOTIFICATIONS --------
    match /notifications/{id} {
      allow read: if signedIn() && (
        isAdmin()
        || resource.data.user_id == request.auth.uid
        || resource.data.user_id == 'all'
        || resource.data.user_id == null
      );
      allow create, update, delete: if isAdmin();
    }

    // -------- SUPPORT & CHAT --------
    match /support_threads/{tid} {
      allow read, update: if signedIn() && (isAdmin() || resource.data.user_id == request.auth.uid);
      allow create: if signedIn() && request.resource.data.user_id == request.auth.uid;
      allow delete: if isAdmin();
      match /messages/{mid} {
        allow read, create: if signedIn() && (isAdmin() || request.auth.uid == tid);
        allow update, delete: if isAdmin();
      }
    }
    match /chat_threads/{tid} {
      allow read, update: if signedIn() && (isAdmin() || resource.data.user_id == request.auth.uid);
      allow create: if signedIn() && request.resource.data.user_id == request.auth.uid;
      allow delete: if isAdmin();
      match /messages/{mid} {
        allow read, create: if signedIn() && (isAdmin() || request.auth.uid == tid);
        allow update, delete: if isAdmin();
      }
    }
    match /support_messages/{uid}/messages/{mid} {
      allow read, create: if signedIn() && (isAdmin() || request.auth.uid == uid);
      allow update, delete: if isAdmin();
    }
    match /chat_messages/{uid}/messages/{mid} {
      allow read, create: if signedIn() && (isAdmin() || request.auth.uid == uid);
      allow update, delete: if isAdmin();
    }

    // -------- APP SETTINGS / CONFIG writes --------
    match /app_settings/site_owner {
      allow create: if signedIn() && noOwnerYet()
        && request.resource.data.owner_uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    match /app_settings/{doc} { allow write: if isAdmin(); }
    match /app_config/{doc}   { allow write: if isAdmin(); }

    // -------- DEFAULT DENY --------
    match /{document=**} { allow read, write: if false; }
  }
}
